# =========================
# Local Database
# =========================
DATABASE_URL="postgresql://storvex_user:storvex_local_password@localhost:5432/storvex_local?schema=public"
DIRECT_URL="postgresql://storvex_user:storvex_local_password@localhost:5432/storvex_local?schema=public"
SHADOW_DATABASE_URL="postgresql://storvex_user:storvex_local_password@localhost:5432/storvex_local_shadow?schema=public"

# =========================
# Server
# =========================
NODE_ENV=development
PORT=5000

# =========================
# Auth - local placeholders only
# Replace before production.
# =========================
JWT_SECRET="local_dev_jwt_secret_change_before_production"
PLATFORM_JWT_SECRET="local_dev_platform_jwt_secret_change_before_production"

# =========================
# Subscription
# =========================
GRACE_DAYS=3

# =========================
# AI - disabled locally unless configured
# =========================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# =========================
# MoMo - local mock mode
# =========================
MOMO_SANDBOX_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MOMO_SANDBOX_API_KEY=""
MOMO_SANDBOX_SUBSCRIPTION_KEY=""
MOMO_CALLBACK_URL="http://localhost:5000/api/payments/momo/callback"
MOMO_API_USER=""
MOMO_MOCK_MODE=true
MOMO_CURRENCY="EUR"

# =========================
# WhatsApp - disabled locally unless configured
# =========================
WHATSAPP_API_VERSION="v24.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# =========================
# OTP
# =========================
DEV_OTP_ECHO=true
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_SEND_COOLDOWN_SECONDS=60
OTP_PEPPER="storvex-dev-pepper"

# =========================
# Email - disabled locally unless configured
# =========================
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"

# =========================
# SMS - disabled locally unless configured
# =========================
SMS_PROVIDER="TWILIO"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""

# =========================
# Object storage - disabled locally unless configured
# =========================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="storvex-private"
R2_PUBLIC_BASE_URL=""
R2_REGION="auto"
R2_SIGNED_URL_TTL_SECONDS=300

OBJECT_STORAGE_ENDPOINT=""
# Local development example:
# OBJECT_STORAGE_ENDPOINT="http://127.0.0.1:4569"
# OBJECT_STORAGE_FORCE_PATH_STYLE="true"
# OBJECT_STORAGE_PUBLIC_BASE_URL="http://127.0.0.1:4569/storvex-private"
# Use real Cloudflare R2 credentials in production.
# Leave empty for Cloudflare R2. Local S3-compatible storage normally needs true.
OBJECT_STORAGE_FORCE_PATH_STYLE=""
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_BUCKET="storvex-private"
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
OBJECT_STORAGE_PUBLIC_BASE_URL=""
